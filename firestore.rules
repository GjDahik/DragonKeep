rules_version = '2';
// DragonKeep: reglas seguras con Firebase Auth (anon) + sesión por PIN.
// Requiere: en la app, signInAnonymously() al cargar y escribir sessions/(uid) al hacer login (tipo + dmId/playerId).
// Deny all por defecto; acceso según request.auth.uid y documento sessions/(uid).

service cloud.firestore {
  match /databases/{database}/documents {

    // ---------- Helpers ----------
    function session() {
      return get(/databases/$(database)/documents/sessions/$(request.auth.uid));
    }
    function isDM() {
      return request.auth != null
        && exists(/databases/$(database)/documents/sessions/$(request.auth.uid))
        && session().data.tipo == 'dm';
    }
    function isPlayer() {
      return request.auth != null
        && exists(/databases/$(database)/documents/sessions/$(request.auth.uid))
        && session().data.tipo == 'player';
    }
    function sessionPlayerId() {
      return session().data.playerId;
    }
    function sessionDmId() {
      return session().data.dmId;
    }

    // ---------- Deny all por defecto ----------
    match /{document=**} {
      allow read, write: if false;
    }

    // ---------- Sesión: solo el propio uid ----------
    match /sessions/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // ---------- Login y creación DM/Jugador: cualquier autenticado (anon) ----------
    match /dms/{dmId} {
      allow read, write: if request.auth != null;
    }
    match /players/{playerId} {
      allow read, write: if request.auth != null;
    }

    // ---------- Ciudades, NPCs, tiendas: lectura autenticados; escritura solo DM ----------
    match /cities/{cityId} {
      allow read: if request.auth != null;
      allow write: if isDM();
      match /playerNotes/{noteId} {
        allow read, write: if request.auth != null;
      }
    }

    match /npcs/{npcId} {
      allow read: if request.auth != null;
      allow write: if isDM();
    }

    match /shops/{shopId} {
      allow read: if request.auth != null;
      allow write: if isDM();
    }

    match /travelingShops/{shopId} {
      allow read: if request.auth != null;
      allow write: if isDM();
    }

    match /transactions/{txId} {
      allow read, write: if request.auth != null;
    }

    match /notifications/{notifId} {
      allow read: if request.auth != null;
      allow write: if isDM();
    }

    match /automation_rules/{ruleId} {
      allow read, write: if isDM();
    }

    match /settings/{docId} {
      allow read: if request.auth != null;
      allow write: if isDM();
    }

    // DM crea/edita/elimina; jugador solo actualiza playerProgress (aceptar, notas, rechazar)
    match /missions/{missionId} {
      allow read: if request.auth != null;
      allow create: if isDM();
      allow update, delete: if isDM() || request.auth != null;
    }

    match /legend_audio/{trackId} {
      allow read: if request.auth != null;
      allow write: if isDM();
    }

    match /rutas_conocidas/{rutaId} {
      allow read: if request.auth != null;
      allow write: if isDM();
    }

    match /bitacora_viajes/{viajeId} {
      allow read, write: if request.auth != null;
    }

    match /map_markers/{markerId} {
      allow read: if request.auth != null;
      allow write: if isDM();
    }

    // Jugador solo su propio doc (si tiene sesión creada); DM puede leer/escribir todos
    match /player_map_markers/{playerId} {
      allow read, write: if request.auth != null
        && (
          isDM()
          || (
            exists(/databases/$(database)/documents/sessions/$(request.auth.uid))
            && playerId == sessionPlayerId()
          )
        );
    }
  }
}
